// Internal adapter for backend (Rust/C++) communication.
// This global bridges the MMapView component and the native map renderer.
// Backend implementations must connect to this adapter to drive the map.

export global MMapAdapter {
    // --- Backend -> UI: rendered frame ---
    in-out property <image> frame;

    // --- Backend -> UI: camera state ---
    in-out property <float> current-lat;
    in-out property <float> current-lon;
    in-out property <float> current-zoom;
    in-out property <float> current-bearing;
    in-out property <float> current-pitch;

    // --- Backend -> UI: map state ---
    in-out property <bool> style-loaded: false;
    in-out property <bool> map-idle: false;

    // --- UI -> Backend: render loop ---
    callback tick();

    // --- UI -> Backend: user interactions ---
    callback mouse-pressed(/* x */ float, /* y */ float);
    callback mouse-released(/* x */ float, /* y */ float);
    callback mouse-moved(/* x */ float, /* y */ float);
    callback wheel-zoomed(/* x */ float, /* y */ float, /* delta */ float);
    callback double-clicked(/* x */ float, /* y */ float, /* shift */ bool);

    // --- UI -> Backend: commands ---
    callback request-style-change(/* url */ string);
    callback request-fly-to(/* lat */ float, /* lon */ float, /* zoom */ float);
    callback request-zoom-change(/* zoom */ float);
    callback request-pitch-change(/* pitch */ float);
    callback request-bearing-change(/* bearing */ float);

    // --- UI -> Backend: initial configuration ---
    // MMapView publishes its declared style/camera here on init. The backend
    // applies these once the map is created (see cpp/main.cpp), so a map
    // declared with a style-url/center/zoom actually opens there instead of
    // silently falling back to the backend default.
    in-out property <bool> initial-config-set: false;
    in-out property <string> initial-style-url;
    in-out property <float> initial-lat;
    in-out property <float> initial-lon;
    in-out property <float> initial-zoom;
    in-out property <float> initial-bearing;
    in-out property <float> initial-pitch;
}
